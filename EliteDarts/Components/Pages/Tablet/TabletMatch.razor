    private int GetPendingCheckoutScore()
    {
        if (Match is null || Match.PendingCheckoutWinnerPlayerId is null)
            return 0;

        var winnerId = Match.PendingCheckoutWinnerPlayerId.Value;

        // VISIT módnál a visit eleji maradék maga a checkout érték
        if (Match.InputMode == MatchInputMode.VisitTotal)
            return Match.VisitStartRemaining;

        var legScores = Scores
            .Where(s => s.LegNo == Match.CurrentLegNo && s.PlayerId == winnerId)
            .OrderBy(s => s.CreatedAt)
            .ThenBy(s => s.Id)
            .ToList();

        if (legScores.Count == 0)
            return 0;

        int remaining = 501;
        int dartsInVisit = 0;
        int visitStartRemaining = 501;

        foreach (var s in legScores)
        {
            var ring = (s.Ring ?? "").ToUpperInvariant();

            if (ring == "VISIT")
                continue;

            if (dartsInVisit == 0)
                visitStartRemaining = remaining;

            var pts = s.Points;
            var after = remaining - pts;

            bool isDoubleOut = ring == "D" || ring == "BULL";
            bool isCheckout = after == 0 && isDoubleOut;
            bool isBust = after < 0 || after == 1 || (after == 0 && !isDoubleOut);

            if (isCheckout)
            {
                return remaining;
            }

            dartsInVisit++;

            if (isBust)
            {
                remaining = visitStartRemaining;
                dartsInVisit = 0;
                continue;
            }

            remaining = after;

            if (dartsInVisit >= 3)
                dartsInVisit = 0;
        }

        return Match.VisitStartRemaining > 0 ? Match.VisitStartRemaining : 0;
    }

    private static bool IsCheckoutPossibleExactly(int score, int darts)
    {
        if (score <= 1 || score > 170)
            return false;

        var allScores = GetAllSingleDartScores().ToArray();
        var finishingScores = GetFinishingDartScores().ToArray();

        return darts switch
        {
            1 => finishingScores.Contains(score),

            2 => allScores.Any(a => finishingScores.Contains(score - a)),

            3 => allScores.Any(a => allScores.Any(b => finishingScores.Contains(score - a - b))),

            _ => false
        };
    }

    private static HashSet<int> GetAllSingleDartScores()
    {
        var result = new HashSet<int> { 0 };

        for (int i = 1; i <= 20; i++)
        {
            result.Add(i);
            result.Add(i * 2);
            result.Add(i * 3);
        }

        result.Add(25);
        result.Add(50);

        return result;
    }

    private static HashSet<int> GetFinishingDartScores()
    {
        var result = new HashSet<int>();

        for (int i = 1; i <= 20; i++)
            result.Add(i * 2);

        result.Add(50);

        return result;
    }

    private void NormalizeCheckoutDartNo()
    {
        if (CanCheckoutIn1)
            CheckoutDartNo = 1;
        else if (CanCheckoutIn2)
            CheckoutDartNo = 2;
        else if (CanCheckoutIn3)
            CheckoutDartNo = 3;
        else
            CheckoutDartNo = 3;
    }


    private async Task QuickVisitAndSubmit(int value)
    {
        VisitTotal = value;
        await SubmitVisit();
    }
}

