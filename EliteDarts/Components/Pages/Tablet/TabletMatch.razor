    private void AppendVisitDigit(int digit)
    {
        var current = VisitTotal?.ToString() ?? "";
        var next = current + digit.ToString();

        if (int.TryParse(next, out var value) && value <= 180)
            VisitTotal = value;
    }

    private void BackspaceVisit()
    {
        var current = VisitTotal?.ToString() ?? "";
        if (string.IsNullOrEmpty(current))
            return;

        current = current[..^1];

        if (string.IsNullOrEmpty(current))
            VisitTotal = null;
        else if (int.TryParse(current, out var value))
            VisitTotal = value;
