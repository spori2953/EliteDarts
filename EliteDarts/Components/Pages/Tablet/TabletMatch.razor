    private async Task StartCameraTurn()
    {
        if (Match is null) return;

        Error = null;
        IsBusy = true;
        StateHasChanged();

        try
        {
            var cvResult = await CvService.ScanVisitAsync();

            if (cvResult == null || !cvResult.Ok)
                throw new Exception(cvResult?.Message ?? "Nem érkezett válasz a kamerától.");

            if (cvResult.Darts.Count == 0)
            {
                LastActionInfo = "A kamera nem érzékelt egyetlen dobást sem.";
                return;
            }

            var result = await MatchPlayService.AddCvVisitAsync(MatchId, cvResult.Darts);

            LastActionInfo = result switch
            {
                "BUST" => "Kamera: bust",
                "CHECKOUT_PENDING" => "Kamera: checkout érzékelve",
                "MATCH_FINISHED" => "Kamera: meccs vége",
                _ => $"Kamera visit mentve ({cvResult.Darts.Count(d => d.Found)} dobás)"
            };

            await Load();

            if (result == "MATCH_FINISHED")
            {
                await PrepareMatchFinishAsync();
            }
        }
        catch (Exception ex)
        {
            Error = $"Kamera hiba: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
            StateHasChanged();
        }
    }

    private async Task Load()
    {
        Error = null;
        IsLoading = true;

        await using var db = await DbFactory.CreateDbContextAsync();

        Board = await db.Boards
            .FirstOrDefaultAsync(b => b.TournamentId == TournamentId && b.BoardNumber == BoardNo);

        Match = await db.Matches
            .Where(m => m.Id == MatchId && m.TournamentId == TournamentId)
            .Include(m => m.Player1)
            .Include(m => m.Player2)
            .FirstOrDefaultAsync();

        if (Match is null || Board is null || Match.BoardId != Board.Id)
        {
            IsLoading = false;
            return;
        }

        var legNo = Match.CurrentLegNo;
        Scores = await db.Scores
            .Where(s => s.MatchId == MatchId && s.LegNo == legNo && s.SetNo == 1)
            .OrderBy(s => s.CreatedAt)
            .ThenBy(s => s.Id)
            .ToListAsync();

        if (Match.PendingCheckoutConfirm)
        {
            NormalizeCheckoutDartNo();
        }

        IsLoading = false;

        if (Match.Status == MatchStatus.Pending
            && Match.LegStarterPlayerId is null
            && Match.Player1Id is not null
            && Match.Player2Id is not null)
        {
            ShowStarterPick = true;
            StarterPickPlayerId = Match.Player1Id.Value;
            StarterPickMode = MatchInputMode.Darts;
        }
        else
        {
            ShowStarterPick = false;
        }
    }

    private void Back() => Nav.NavigateTo($"/tablet/{TournamentId}/{BoardNo}");

    private string FormatThrow(Score s)
    {
        var ring = (s.Ring ?? "").ToUpperInvariant();
        return ring switch
        {
            "BULL" => "Bull",
            "25" => "25",
            "S" => $"Szimpla {s.Sector}",
            "D" => $"Dupla {s.Sector}",
            "T" => $"Tripla {s.Sector}",
            _ => $"{s.Ring} {s.Sector}"
        };
    }

    private string FormatThrowShort(Score s)
    {
        var ring = (s.Ring ?? "").ToUpperInvariant();
        return ring switch
        {
            "VISIT" => $"V{s.Points}",
            "BULL" => "BULL",
            "25" => "25",
            "S" => $"S{s.Sector}",
            "D" => $"D{s.Sector}",
            "T" => $"T{s.Sector}",
            _ => $"{ring}{s.Sector}"
        };
    }

    private int GetRemaining(int playerId)
    {
        if (Match is null) return 501;
        if (Match.Player1Id == playerId) return Match.P1Remaining;
        if (Match.Player2Id == playerId) return Match.P2Remaining;
        return 501;
    }

    private int GetCurrentThrowerId()
    {

        if (Match is null || Match.Player1Id is null || Match.Player2Id is null)
            return 0;

        if (Match.CurrentPlayerId is not null)
            return Match.CurrentPlayerId.Value;

        var p1 = Match.Player1Id.Value;
        var p2 = Match.Player2Id.Value;

        var p1Darts = Scores.Count(s => s.PlayerId == p1);
        var p2Darts = Scores.Count(s => s.PlayerId == p2);

        var p1Visits = p1Darts / 3;
        var p2Visits = p2Darts / 3;

        if (p1Visits == p2Visits)
        {
            var p1InVisit = p1Darts % 3;
            return (p1InVisit < 3) ? p1 : p2;
        }

        return (p1Visits > p2Visits) ? p2 : p1;
    }

    private List<VisitVm> GetVisits(int playerId)
    {
        var list = Scores
            .Where(s => s.PlayerId == playerId)
            .OrderBy(s => s.CreatedAt)
            .ThenBy(s => s.Id)
            .ToList();

        if (list.Any(x => (x.Ring ?? "").ToUpperInvariant() == "VISIT"))
        {
            var visitList = new List<VisitVm>();
            var no = 1;

            foreach (var s in list)
            {
                visitList.Add(new VisitVm
                {
                    VisitNo = no++,
                    Throws = new List<Score> { s },
                    Total = s.Points
                });
            }
            return visitList;
        }

        var visits = new List<VisitVm>();
        var visitNo = 1;

        for (int i = 0; i < list.Count; i += 3)
        {
            var chunk = list.Skip(i).Take(3).ToList();
            visits.Add(new VisitVm
            {
                VisitNo = visitNo++,
                Throws = chunk,
                Total = chunk.Sum(x => x.Points)
            });
        }
        return visits;
    }

    private class VisitVm
    {
        public int VisitNo { get; set; }
        public List<Score> Throws { get; set; } = new();
        public int Total { get; set; }
    }

