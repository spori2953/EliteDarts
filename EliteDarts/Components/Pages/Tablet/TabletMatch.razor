    private async Task SaveEdit()
{
    Error = null;
    IsBusy = true;

    try
    {
        if (IsVisitEditMode)
        {
            if (EditVisitPoints < 0 || EditVisitPoints > 180)
                throw new Exception("A kör pontszáma 0 és 180 között lehet.");

            if (IsEditExisting)
            {
                    await using var db = await DbFactory.CreateDbContextAsync();

                    if (EditingScoreId is not int editingScoreId)
                        throw new Exception("Nincs kiválasztott visit rekord.");

                    var score = await db.Scores.FirstOrDefaultAsync(s => s.Id == editingScoreId);
                    if (score is null)
                        throw new Exception("A visit rekord nem található.");

                    score.Ring = "VISIT";
                    score.Sector = null;
                    score.Points = EditVisitPoints;
                    score.Source = ThrowSource.Manual;

                    await db.SaveChangesAsync();
                    await MatchPlayService.RebuildCurrentLegStateAsync(MatchId);
            }
            else
            {
                if (AddPlayerId is null) return;

                var result = await MatchPlayService.AddVisitTotalAsync(MatchId, EditVisitPoints, ThrowSource.Manual);
                LastActionInfo = result;
            }
        }
        else
        {
            if (EditRing is "S" or "D" or "T")
            {
                if (EditSector is null or < 1 or > 20)
                    throw new Exception("Szimpla/dupla/tripla esetén kötelező 1-20 közötti szektort választani.");
            }
            else
            {
                EditSector = null;
            }

            if (IsEditExisting)
            {
                if (EditingScoreId is null) return;
                await ScoreService.UpdateThrowAsync(EditingScoreId.Value, EditRing, EditSector);
                await MatchPlayService.RebuildCurrentLegStateAsync(MatchId);
            }
            else
            {
                if (AddPlayerId is null) return;
                var result = await MatchPlayService.AddThrowAsync(MatchId, EditRing, EditSector, ThrowSource.Manual);
                LastActionInfo = result;
            }
        }
        await Load();
        CloseEdit();
    }
    catch (Exception ex)
    {
        Error = ex.Message;
    }
    finally
    {
        IsBusy = false;
    }
}

