    private bool CanCheckoutIn3 => IsCheckoutPossibleExactly(PendingCheckoutScore, 3);

    private string _editRing = "S";
    private string EditRing
    {
        get => _editRing;
        set
        {
            _editRing = (value ?? "S").ToUpperInvariant();

            if (_editRing is "25" or "BULL")
                EditSector = null;
            else if (EditSector is null)
                EditSector = 20;
        }
    }
    private int? EditSector = 20;

