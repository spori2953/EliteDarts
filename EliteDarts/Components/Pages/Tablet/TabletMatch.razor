@page "/tablet/{TournamentId:int}/{BoardNo:int}/match/{MatchId:int}"
@using EliteDarts.Data
@using EliteDarts.Domain.Entities
@using EliteDarts.Entities
@using EliteDarts.Services
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ScoreService ScoreService
@inject NavigationManager Nav
@inject MatchPlayService MatchPlayService
@inject CvIntegrationService CvService
@inject MatchStatisticsService MatchStatisticsService


<h2>Meccs – Tábla @BoardNo</h2>

@if (IsLoading)
{
    <p>Betöltés...</p>
}
else if (Match is null || Board is null)
{
    <div class="alert alert-danger">A meccs vagy a tábla nem található / nem ehhez a táblához tartozik.</div>
}
else if (Match.Player1Id is null || Match.Player2Id is null || Match.Player1 is null || Match.Player2 is null)
{
    <div class="alert alert-warning">
        Ez a meccs még nem teljes (BYE vagy nincs meg mindkét játékos). Tablet nézeten csak akkor jelenjen meg, ha mindkét játékos ismert.
    </div>

    <button class="btn btn-outline-secondary" @onclick="Back">Vissza</button>
}
else
{
    <div class="card p-3 mb-3">
        <div class="fw-semibold">
            @Match.Player1.FullName <span class="text-muted">vs</span> @Match.Player2.FullName
        </div>
        <div class="mt-1">
            <span class="badge text-bg-success">@(Match.LegsPlayer1 ?? 0)</span>
            <span class="badge text-bg-success ms-2">@(Match.LegsPlayer2 ?? 0)</span>
        </div>
        <div class="text-muted mt-1">
            Kör @Match.RoundNo • Best of @Match.BestOfLegs • Leg: @Match.CurrentLegNo
        </div>

        <div class="mt-2 d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-secondary" @onclick="Back">Vissza</button>
            <button class="btn btn-outline-secondary" @onclick="Load">Frissítés</button>
        </div>

        <div class="text-muted mt-1">
            Állapot: <strong>@Match.Status</strong>
        </div>
    </div>


        var currentPlayerId = GetCurrentThrowerId();
        var p1Active = currentPlayerId == Match.Player1Id.Value;
        var p2Active = currentPlayerId == Match.Player2Id.Value;

        var p1Remaining = GetRemaining(Match.Player1Id.Value);
        var p2Remaining = GetRemaining(Match.Player2Id.Value);

        var p1Visits = GetVisits(Match.Player1Id.Value);
        var p2Visits = GetVisits(Match.Player2Id.Value);


    <div class="tablet-players">
        <!-- Player 1 -->
        <div class="tablet-player-col">
            <div class="player-card @(p1Active ? "active" : "inactive")">
                <div class="player-header">
                    <div>
                        <div class="player-name">@Match.Player1.FullName</div>
                        <div class="sub">
                            @(p1Active ? "Ő következik" : "Várakozik")
                        </div>
                    </div>

                    <div class="text-end">
                        <div class="sub">Hátralévő</div>
                        <div class="remain">@p1Remaining</div>
                    </div>
                </div>

                @if (Match.InputMode == MatchInputMode.VisitTotal)
                {
                    <div class="elite-keypad-wrap">
                        <div class="sub mb-2">Visit pont</div>

                        <div class="elite-keypad-display">
                            @(VisitTotal?.ToString() ?? "")
                        </div>

                        <div class="elite-keypad-grid">
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(1)" disabled="@(!p1Active || IsBusy)">1</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(2)" disabled="@(!p1Active || IsBusy)">2</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(3)" disabled="@(!p1Active || IsBusy)">3</button>

                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(4)" disabled="@(!p1Active || IsBusy)">4</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(5)" disabled="@(!p1Active || IsBusy)">5</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(6)" disabled="@(!p1Active || IsBusy)">6</button>

                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(7)" disabled="@(!p1Active || IsBusy)">7</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(8)" disabled="@(!p1Active || IsBusy)">8</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(9)" disabled="@(!p1Active || IsBusy)">9</button>

                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(0)" disabled="@(!p1Active || IsBusy)">0</button>
                            <button class="elite-keypad-btn elite-keypad-btn--warn" @onclick="BackspaceVisit" disabled="@(!p1Active || IsBusy)">←</button>
                            <button class="elite-keypad-btn elite-keypad-btn--warn" @onclick="ClearVisit" disabled="@(!p1Active || IsBusy)">CLR</button>
                        </div>

                        <div class="elite-keypad-quick">
                            @foreach (var v in QuickVisits)
                            {
                                <button class="elite-btn elite-btn--outline"
                                        @onclick="() => SetQuickVisit(v)"
                                        disabled="@(!p1Active || IsBusy)">
                                    @v
                                </button>
                            }
                        </div>

                        <div class="mt-3">
                            <button class="elite-btn elite-btn--green w-100"
                                    @onclick="SubmitVisit"
                                    disabled="@((IsBusy) || (!p1Active))">
                                Visit mentése
                            </button>
                        </div>
                    </div>
                }
                else if (Match.InputMode == MatchInputMode.Camera)
                {
                    <div class="mt-3">
                        <button class="btn @(p1Active ? "btn-primary" : "btn-outline-secondary") w-100 py-3 fw-bold fs-5"
                                @onclick="() => StartCameraTurn()"
                                disabled="@(IsBusy || !p1Active || Match.PendingCheckoutConfirm)">
                            @if (IsBusy && p1Active)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span> 
                                @("Kamera figyel, dobhatsz!")
                            }
                            else
                            {
                                @("Kamera indítása - Kör megkezdése")
                            }
                        </button>
                        @if (p1Active && Match.PendingCheckoutConfirm)
                        {
                            <div class="text-danger mt-1 small">Előbb igazold vissza a kiszállót!</div>
                        }
                    </div>

                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => UndoLastDart()" disabled="@IsBusy">
                            ↩ Utolsó nyíl vissza
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartAddThrow(Match.Player1Id.Value)">
                            Kézi felvitel
                        </button>
                    </div>
                }
                else
                {
                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <button class="btn @(p1Active ? "btn-success" : "btn-outline-secondary")"
                                @onclick="() => StartAddThrow(Match.Player1Id.Value)">
                            + 1 nyíl
                        </button>
                        <button class="btn btn-outline-danger" @onclick="() => UndoLastDart()" disabled="@IsBusy">
                            ↩ Utolsó nyíl vissza
                        </button>
                    </div>
                }
                <hr />

                <div class="fw-semibold mb-2">Dobások</div>
                @if (p1Visits.Count == 0)
                {
                    <div class="text-muted">Még nincs dobás.</div>
                }
                else
                {
                    <div style="display:flex; flex-direction:column; gap:10px;">
                        @foreach (var v in p1Visits)
                        {
                            <div class="visit">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="fw-semibold">Visit @v.VisitNo</div>
                                    <div class="sub">Összesen: <strong>@v.Total</strong></div>
                                </div>
                                <div>
                                    @foreach (var s in v.Throws)
                                    {
                                        <span class="pill clickable" title="Kattints a szerkesztéshez"
                                              @onclick="() => StartEditThrow(s.Id)">
                                              <strong>@s.Points</strong>
                                        </span>
                                    }
                                </div>

                                <div class="sub mt-2">
                                    Utolsó forrás: @v.Throws.Last().Source
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Player 2 -->
        <div class="tablet-player-col">
            <div class="player-card @(p2Active ? "active" : "inactive")">
                <div class="player-header">
                    <div>
                        <div class="player-name">@Match.Player2.FullName</div>
                        <div class="sub">
                            @(p2Active ? "Ő következik" : "Várakozik")
                        </div>
                    </div>

                    <div class="text-end">
                        <div class="sub">Hátralévő</div>
                        <div class="remain">@p2Remaining</div>
                    </div>
                </div>

                @if (Match.InputMode == MatchInputMode.VisitTotal)
                {
                    <div class="elite-keypad-wrap">
                        <div class="sub mb-2">Visit pont</div>

                        <div class="elite-keypad-display">
                            @(VisitTotal?.ToString() ?? "")
                        </div>

                        <div class="elite-keypad-grid">
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(1)" disabled="@(!p2Active || IsBusy)">1</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(2)" disabled="@(!p2Active || IsBusy)">2</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(3)" disabled="@(!p2Active || IsBusy)">3</button>

                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(4)" disabled="@(!p2Active || IsBusy)">4</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(5)" disabled="@(!p2Active || IsBusy)">5</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(6)" disabled="@(!p2Active || IsBusy)">6</button>

                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(7)" disabled="@(!p2Active || IsBusy)">7</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(8)" disabled="@(!p2Active || IsBusy)">8</button>
                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(9)" disabled="@(!p2Active || IsBusy)">9</button>

                            <button class="elite-keypad-btn" @onclick="() => AppendVisitDigit(0)" disabled="@(!p2Active || IsBusy)">0</button>
                            <button class="elite-keypad-btn elite-keypad-btn--warn" @onclick="BackspaceVisit" disabled="@(!p2Active || IsBusy)">←</button>
                            <button class="elite-keypad-btn elite-keypad-btn--warn" @onclick="ClearVisit" disabled="@(!p2Active || IsBusy)">CLR</button>
                        </div>

                        <div class="elite-keypad-quick">
                            @foreach (var v in QuickVisits)
                            {
                                <button class="elite-btn elite-btn--outline"
                                        @onclick="() => SetQuickVisit(v)"
                                        disabled="@(!p2Active || IsBusy)">
                                    @v
                                </button>
                            }
                        </div>

                        <div class="mt-3">
                            <button class="elite-btn elite-btn--green w-100"
                                    @onclick="SubmitVisit"
                                    disabled="@((IsBusy) || (!p2Active))">
                                Visit mentése
                            </button>
                        </div>
                    </div>
                }
                else if (Match.InputMode == MatchInputMode.Camera)
                {
                    <div class="mt-3">
                        <button class="btn @(p2Active ? "btn-primary" : "btn-outline-secondary") w-100 py-3 fw-bold fs-5"
                                @onclick="() => StartCameraTurn()"
                                disabled="@(IsBusy || !p2Active || Match.PendingCheckoutConfirm)">
                            @if (IsBusy && p2Active)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                @("Kamera figyel, dobhatsz!")
                            }
                            else
                            {
                                @("Kamera indítása - Kör megkezdése")
                            }
                        </button>
                        @if (p2Active && Match.PendingCheckoutConfirm)
                        {
                            <div class="text-danger mt-1 small">Előbb igazold vissza a kiszállót!</div>
                        }
                    </div>

                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => UndoLastDart()" disabled="@IsBusy">
                            ↩ Utolsó nyíl vissza
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartAddThrow(Match.Player2Id.Value)">
                            Kézi felvitel
                        </button>
                    </div>
                }
                else
                {
                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <button class="btn @(p2Active ? "btn-success" : "btn-outline-secondary")"
                                @onclick="() => StartAddThrow(Match.Player2Id.Value)">
                            + 1 nyíl
                        </button>
                        <button class="btn btn-outline-danger" @onclick="() => UndoLastDart()" disabled="@IsBusy">
                            ↩ Utolsó nyíl vissza
                        </button>
                    </div>
                }

                <hr />

                <div class="fw-semibold mb-2">Dobások</div>

                @if (p2Visits.Count == 0)
                {
                    <div class="text-muted">Még nincs dobás.</div>
                }
                else
                {
                    <div style="display:flex; flex-direction:column; gap:10px;">
                        @foreach (var v in p2Visits)
                        {
                            <div class="visit">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="fw-semibold">Visit @v.VisitNo</div>
                                    <div class="sub">Összesen: <strong>@v.Total</strong></div>
                                </div>

                                <div>
                                    @foreach (var s in v.Throws)
                                    {
                                        <span class="pill clickable" title="Kattints a szerkesztéshez"
                                              @onclick="() => StartEditThrow(s.Id)">
                                              <strong>@s.Points</strong>
                                        </span>
                                    }
                                </div>

                                <div class="sub mt-2">
                                    Utolsó forrás: @v.Throws.Last().Source
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <div class="alert alert-danger mt-3">@Error</div>
    }

    @if (ShowStarterPick && Match is not null && Match.Player1 is not null && Match.Player2 is not null)
    {
        <div class="elite-modal-backdrop">
            <div class="elite-modal">
                <div class="elite-modal__header">
                    <h3 class="elite-modal__title">Meccs indítása</h3>
                    <div class="elite-modal__subtitle">
                        Válaszd ki, ki kezdje az első leget és milyen beviteli módban fusson a mérkőzés.
                    </div>
                </div>

                <div class="elite-modal__body">
                    <div class="elite-section-title" style="margin-top:0;">Ki kezdi a mérkőzést?</div>

                    <div class="elite-choice-list mb-4">
                        <div class="elite-choice-card @(StarterPickPlayerId == Match.Player1Id.Value ? "active" : "")">
                            <label class="elite-choice-label">
                                <input class="form-check-input"
                                       type="radio"
                                       name="starter"
                                       checked="@(StarterPickPlayerId == Match.Player1Id.Value)"
                                       @onchange="() => StarterPickPlayerId = Match.Player1Id.Value" />
                                <span>@Match.Player1.FullName</span>
                            </label>
                        </div>

                        <div class="elite-choice-card @(StarterPickPlayerId == Match.Player2Id.Value ? "active" : "")">
                            <label class="elite-choice-label">
                                <input class="form-check-input"
                                       type="radio"
                                       name="starter"
                                       checked="@(StarterPickPlayerId == Match.Player2Id.Value)"
                                       @onchange="() => StarterPickPlayerId = Match.Player2Id.Value" />
                                <span>@Match.Player2.FullName</span>
                            </label>
                        </div>
                    </div>

                    <div class="elite-section-title">Beviteli mód</div>

                    <div class="elite-mode-grid">
                        <button type="button"
                                class="elite-mode-btn @(StarterPickMode == MatchInputMode.Darts ? "active" : "")"
                                @onclick="() => StarterPickMode = MatchInputMode.Darts">
                            <span class="elite-mode-btn__title">Nyilanként</span>
                            <span class="elite-mode-btn__desc">Minden dobás nyilanként kerül mentésre.</span>
                        </button>

                        <button type="button"
                                class="elite-mode-btn @(StarterPickMode == MatchInputMode.VisitTotal ? "active" : "")"
                                @onclick="() => StarterPickMode = MatchInputMode.VisitTotal">
                            <span class="elite-mode-btn__title">Pontszám</span>
                            <span class="elite-mode-btn__desc">A dobás körönként kerül mentésre.</span>
                        </button>

                        <button type="button"
                                class="elite-mode-btn @(StarterPickMode == MatchInputMode.Camera ? "active" : "")"
                                @onclick="() => StarterPickMode = MatchInputMode.Camera">
                            <span class="elite-mode-btn__title">Kamera</span>
                            <span class="elite-mode-btn__desc">A kamera automatikusan megpróbálja felismerni a dobásokat.</span>
                        </button>
                    </div>

                    <div class="elite-modal-note">
                        A következő legek automatikusan váltott kezdéssel mennek.
                    </div>
                </div>

                <div class="elite-modal__footer">
                    <button class="elite-btn elite-btn--outline" @onclick="Back">Mégse</button>
                    <button class="elite-btn elite-btn--green" @onclick="ConfirmStarterAndStart" disabled="@IsBusy">
                        @(IsBusy ? "Indítás..." : "Meccs indítása")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (Match?.PendingCheckoutConfirm == true && Match.PendingCheckoutWinnerPlayerId is not null)
    {
        var winnerName = (Match.PendingCheckoutWinnerPlayerId == Match.Player1Id)
            ? Match.Player1!.FullName
            : Match.Player2!.FullName;

        <div class="elite-modal-backdrop" style="z-index:2500;">
            <div class="elite-modal">
                <div class="elite-modal__header">
                    <h3 class="elite-modal__title">Checkout</h3>
                    <div class="elite-modal__subtitle">
                        <strong>@winnerName</strong> kiszállt <strong>@PendingCheckoutScore</strong> pontról.
                        Erősítsd meg a leg lezárását.
                    </div>
                </div>

                <div class="elite-modal__body">
                    <div class="elite-section-title" style="margin-top:0;">
                        Hányadik nyíllal dobta meg a kiszállót?
                    </div>

                    @if (!CanCheckoutIn1 && !CanCheckoutIn2 && !CanCheckoutIn3)
                    {
                        <div class="alert alert-danger">
                            Erről az értékről (@PendingCheckoutScore) nem lehetséges szabályos kiszálló.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2 flex-wrap">
                            @if (CanCheckoutIn1)
                            {
                                <button type="button"
                                        class="elite-btn @(CheckoutDartNo == 1 ? "elite-btn--green" : "elite-btn--outline")"
                                        @onclick="() => CheckoutDartNo = 1">
                                    1. nyíl
                                </button>
                            }

                            @if (CanCheckoutIn2)
                            {
                                <button type="button"
                                        class="elite-btn @(CheckoutDartNo == 2 ? "elite-btn--green" : "elite-btn--outline")"
                                        @onclick="() => CheckoutDartNo = 2">
                                    2. nyíl
                                </button>
                            }

                            @if (CanCheckoutIn3)
                            {
                                <button type="button"
                                        class="elite-btn @(CheckoutDartNo == 3 ? "elite-btn--green" : "elite-btn--outline")"
                                        @onclick="() => CheckoutDartNo = 3">
                                    3. nyíl
                                </button>
                            }
                        </div>
                    }
                </div>

                <div class="elite-modal__footer">
                    <button class="elite-btn elite-btn--outline" @onclick="CancelCheckout" disabled="@IsBusy">
                        Mégse
                    </button>
                    <button class="elite-btn elite-btn--green"
                            @onclick="ConfirmCheckout"
                            disabled="@IsBusy">
                        Leg lezárása
                    </button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(LastActionInfo))
    {
        <div class="alert alert-info mt-2">@LastActionInfo</div>
    }

    @if (EditOpen)
    {
        <div class="elite-modal-backdrop" style="z-index:3000;">
            <div class="elite-modal" style="max-width:420px;">
                <div class="elite-modal__header">
                    <h3 class="elite-modal__title">
                        @(IsVisitEditMode ? "Kör szerkesztése" : "Dobás szerkesztése")
                    </h3>
                    <div class="elite-modal__subtitle">
                        @EditHeader
                    </div>
                </div>

                <div class="elite-modal__body">
                    @if (IsVisitEditMode)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Kör pontszám</label>
                            <input class="form-control elite-input"
                                   type="number"
                                   min="0"
                                   max="180"
                                   @bind="EditVisitPoints" />
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ring</label>
                            <select class="form-select elite-input" style="height:46px;" @bind="EditRing">
                                <option value="S">Single</option>
                                <option value="D">Double</option>
                                <option value="T">Triple</option>
                                <option value="25">25</option>
                                <option value="BULL">Bull</option>
                            </select>
                        </div>

                        @if (EditRing is "S" or "D" or "T")
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Sector</label>
                                <input class="form-control elite-input"
                                       type="number"
                                       min="0"
                                       max="20"
                                       @bind="EditSector" />
                            </div>
                        }

                        <div class="elite-choice-card active">
                            <div class="fw-semibold">Preview</div>
                            <div class="mt-1">@PreviewPoints pont</div>
                        </div>
                    }
                </div>

                <div class="elite-modal__footer" style="justify-content:space-between;">
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="elite-btn elite-btn--outline" @onclick="CloseEdit">
                            Mégse
                        </button>

                        @if (IsEditExisting)
                        {
                            <button class="elite-btn elite-btn--red" @onclick="DeleteEdit">
                                Törlés
                            </button>
                        }
                    </div>

                    <button class="elite-btn elite-btn--green" @onclick="SaveEdit">
                        Mentés
                    </button>
                </div>
            </div>
        </div>
    }

    @if (ShowMatchFinishConfirm && MatchStats is not null)
    {
        <div class="elite-modal-backdrop" style="z-index:2600;">
            <div class="elite-modal">
                <div class="elite-modal__header">
                    <h3 class="elite-modal__title">Mérkőzés vége</h3>
                    <div class="elite-modal__subtitle">
                        @MatchFinishText
                    </div>
                </div>

                <div class="elite-modal__body">
                    <div class="elite-modal-note">
                        Megerősítés után megjelennek a mérkőzés statisztikái.
                    </div>
                </div>

                <div class="elite-modal__footer">
                    <button class="elite-btn elite-btn--outline" @onclick="(() => ShowMatchFinishConfirm = false)">
                        Mégse
                    </button>
