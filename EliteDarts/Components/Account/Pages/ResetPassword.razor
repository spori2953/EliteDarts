@page "/Account/ResetPassword"
@using Microsoft.Extensions.Primitives
@inject NavigationManager Nav

<div class="elite-shell">
    <div style="display:flex; justify-content:center; margin-top:70px;">
        <div class="elite-login-card">

            <div class="elite-login-title">
                Új jelszó
            </div>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="alert alert-danger">@ErrorMessage</div>
            }

            <form method="post" action="/account/reset-password">
                <AntiforgeryToken />

                <input type="hidden" name="Email" value="@Email" />
                <input type="hidden" name="Code" value="@Code" />

                <div class="mb-3">
                    <input class="elite-input elite-login-input"
                           type="password"
                           name="Password"
                           placeholder="Új jelszó" />
                </div>

                <div class="mb-3">
                    <input class="elite-input elite-login-input"
                           type="password"
                           name="ConfirmPassword"
                           placeholder="Jelszó újra" />
                </div>

                <div style="display:flex; justify-content:center;">
                    <button type="submit"
                            class="elite-btn elite-btn--green elite-login-btn">
                        Mentés
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@code {
    private string? Email;
    private string? Code;
    private string? ErrorMessage;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        Email = query["email"].FirstOrDefault();
        Code = query["code"].FirstOrDefault();

        if (query.TryGetValue("error", out var error))
        {
            var errorValue = error.FirstOrDefault();

            ErrorMessage = errorValue switch
            {
                "missing" => "Hiányzó adatok.",
                "nomatch" => "A jelszavak nem egyeznek.",
                "badcode" => "Hibás token.",
                _ => null
            };
        }
    }
}