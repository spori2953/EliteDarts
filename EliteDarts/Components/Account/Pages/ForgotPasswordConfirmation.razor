@page "/Account/ForgotPasswordConfirmation"
@inject NavigationManager Nav

<div class="elite-shell">
    <div style="display:flex; justify-content:center; margin-top:80px;">
        <div class="elite-login-card" style="text-align:center;">

            <div class="elite-login-title">
                Jelszó visszaállítás
            </div>

            @if (!string.IsNullOrEmpty(ResetLink))
            {
                <div class="alert alert-warning">
                    <strong>DEV mód:</strong><br />
                    Kattints a linkre:
                </div>

                <a class="elite-btn elite-btn--green"
                   href="@ResetLink">
                    Jelszó visszaállítása
                </a>
            }
            else
            {
                <div class="text-muted">
                    Ha létezik ilyen email, elküldtük a visszaállító linket.
                </div>
            }

        </div>
    </div>
</div>

@code {
    private string? ResetLink;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);

        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .TryGetValue("resetLink", out var link))
        {
            ResetLink = link;
        }
    }
}