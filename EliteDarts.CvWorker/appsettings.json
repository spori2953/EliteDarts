{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CvSettings": {
    "DefaultCameraIndex": 1,
    "DefaultWidth": 1920,
    "DefaultHeight": 1080,
    "SaveDebugImages": true,
    "DebugDir": "debug_images",
    "TargetWarpSize": 800,
    "WarpRotationDegrees": -36.0,
    "WarpOffsetX": 10,
    "WarpOffsetY": 0,
    "WarpScale": 1.0,
    "DoubleRingRatio": 0.754,
    "CannyThreshold1": 60,
    "CannyThreshold2": 160,
    "MaxEllipseRatio": 1.35,
    "EmptyTimeoutMs": 12000,
    "EmptyThreshold": 25,
    "EmptyPixels": 3500,
    "EmptyStableFrames": 8,
    "MotionTimeoutMs": 8000,
    "MotionPixels": 2500,
    "MotionThreshold": 25,
    "DefaultSettleMs": 350,
    "DiffThreshold": 25,
    "MinContourArea": 150
  }
}